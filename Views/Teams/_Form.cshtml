@model TeamFormViewModel

<div class="card panel-card">
    <div class="card-body">
        <form method="post">
            <input asp-for="Id" type="hidden" />
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="Name" class="form-label"></label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="ProjectId" class="form-label">Project</label>
                    <select asp-for="ProjectId" asp-items="Model.ProjectOptions" class="form-select"></select>
                </div>
                <div class="col-md-6">
                    <label asp-for="TeamLeadId" class="form-label">Team Lead</label>
                    <select asp-for="TeamLeadId" asp-items="Model.TeamLeadOptions" class="form-select"></select>
                </div>
                <div class="col-md-6">
                    <label asp-for="MemberIds" class="form-label">Members</label>
                    <select asp-for="MemberIds" asp-items="Model.MemberOptions" class="form-select" multiple size="8"></select>
                </div>
            </div>
            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn btn-primary">Save</button>
                <a class="btn btn-outline-secondary" asp-action="Index">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
