@model DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    ViewData["Subtitle"] = "Overview of people, teams, projects and leave approvals.";
}

<div class="hero">
    <div>
        <div class="eyebrow">Welcome back</div>
        <h2>@Model.CurrentUser.FullName</h2>
        <p>@Model.CurrentRoleName with access to daily vacation operations.</p>
    </div>
    <a class="btn btn-light" asp-controller="Leaves" asp-action="Create">New leave request</a>
</div>

<div class="stats-grid">
    <div class="stat-card"><span>Users</span><strong>@Model.TotalUsers</strong></div>
    <div class="stat-card"><span>Teams</span><strong>@Model.TotalTeams</strong></div>
    <div class="stat-card"><span>Projects</span><strong>@Model.TotalProjects</strong></div>
    <div class="stat-card"><span>Leave Requests</span><strong>@Model.TotalLeaveRequests</strong></div>
    <div class="stat-card"><span>Pending Approvals</span><strong>@Model.PendingApprovals</strong></div>
</div>

<div class="card panel-card">
    <div class="card-body">
        <h3 class="h5">Your latest requests</h3>
        <div class="table-responsive">
            <table class="table align-middle">
                <thead>
                    <tr>
                        <th>Type</th>
                        <th>Period</th>
                        <th>Created</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model.RecentLeaves)
                {
                    <tr>
                        <td>@item.Leave.Type</td>
                        <td>@item.Leave.StartDate.ToShortDateString() - @item.Leave.EndDate.ToShortDateString()</td>
                        <td>@item.Leave.CreatedOn.ToShortDateString()</td>
                        <td>
                            @if (item.Leave.IsApproved)
                            {
                                <span class="badge bg-success">Approved</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">Pending</span>
                            }
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
