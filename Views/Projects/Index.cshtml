@model ProjectIndexViewModel
@{
    ViewData["Title"] = "Projects";
    ViewData["Subtitle"] = "Project catalogue with search by name and description.";
    var isCeo = User.IsInRole("CEO");
}

<div class="toolbar">
    <form method="get" class="row g-2 align-items-end">
        <div class="col-md-5">
            <label class="form-label">Search</label>
            <input name="search" value="@Model.Search" class="form-control" placeholder="Project name or description" />
        </div>
        <div class="col-md-2">
            <label class="form-label">Page size</label>
            <select name="pageSize" class="form-select">
                <option selected="@(Model.Projects.PageSize == 10)">10</option>
                <option selected="@(Model.Projects.PageSize == 25)">25</option>
                <option selected="@(Model.Projects.PageSize == 50)">50</option>
            </select>
        </div>
        <div class="col-md-5 d-flex gap-2">
            <button class="btn btn-primary" type="submit">Apply</button>
            <a class="btn btn-outline-secondary" asp-action="Index">Reset</a>
            @if (isCeo)
            {
                <a class="btn btn-dark" asp-action="Create">New project</a>
            }
        </div>
    </form>
</div>

<div class="card panel-card">
    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Description</th>
                    <th>Teams</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var item in Model.Projects.Items)
            {
                <tr>
                    <td>@item.Project.Name</td>
                    <td>@item.Project.Description</td>
                    <td>@item.TeamCount</td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-id="@item.Project.Id">Details</a>
                        @if (isCeo)
                        {
                            <a class="btn btn-sm btn-outline-secondary" asp-action="Edit" asp-route-id="@item.Project.Id">Edit</a>
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>

<partial name="_Pager" model="Model.Projects" />
